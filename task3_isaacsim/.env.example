# Task 3 robot/gripper profile used by the launcher (robotiq|panda).
GRIPPER_PROFILE="robotiq"

# ros_joint_republisher calibration. The launcher overrides the closed value
# for --gripper panda (0.04) and robotiq (0.8).
REPUBLISHER_BRIDGE_PREFIX="/bridge"
REPUBLISHER_ISAAC_PREFIX="/isaac"
REPUBLISHER_GRIPPER_OPEN_POSITION="0.0"
REPUBLISHER_GRIPPER_CLOSED_POSITION="0.8"
REPUBLISHER_GRIPPER_INVERT="false"

# Sim-side adapters to run (keyboard, gello, or both).
TELEOP_ADAPTERS="keyboard gello"
CONTROLLER_MODE="position"
