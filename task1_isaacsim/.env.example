# Environment for the Task 1 ROS 2 helper services (task1_isaacsim/docker-compose.yml).
# Copy to .env (auto-read by docker compose) to override defaults; copying is optional
# because docker-compose.yml already falls back to these same values.

# ros_joint_republisher: remap /bridge/* -> /isaac/* and calibrate the gripper.
REPUBLISHER_BRIDGE_PREFIX="/bridge"
REPUBLISHER_ISAAC_PREFIX="/isaac"
REPUBLISHER_GRIPPER_OPEN_POSITION="0.0"
REPUBLISHER_GRIPPER_CLOSED_POSITION="0.8"
REPUBLISHER_GRIPPER_INVERT="true"

# teleop_adapters is retained for keyboard -> base conversion. GELLO uses the
# dedicated gello_pedal_teleop service, which already starts gello_to_bridge.
TELEOP_ADAPTERS="keyboard"

# Host checkout mounted into task1_gello_pedal_teleop. Relative paths are
# resolved from task1_isaacsim/; the default expects teleoperation next to the
# benchmark repository.
TELEOPERATION_ROOT="../../teleoperation"
GELLO_CONFIG_FILE="franka_gello_duo.yaml"


# Controller mode used by scripts/run_isaaclab_newton_teleop.sh (none|position).
CONTROLLER_MODE="position"
